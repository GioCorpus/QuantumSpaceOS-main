# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Q#
*.qs
/bin/
/obj/

# Temporary files
*.tmp
*.bak
*.orig

# Rustup
.rustup/

# Misc
*.img
*.img.xz
*.tar
*.gz

